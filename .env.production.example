# Production Environment Variables for Vercel Deployment

# Database (Required - Use Supabase, Neon, or PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/assetflow"

# Authentication (Required - Generate strong secrets)
JWT_SECRET="your-production-jwt-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="your-production-session-secret-min-32-chars"

# Email Configuration (Optional - For notifications)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASSWORD="your-resend-api-key"
SMTP_FROM="noreply@yourdomain.com"

# SMS Configuration (Optional - For Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Frontend URLs (Required - Update with your Vercel domain)
NEXT_PUBLIC_API_URL="https://your-project.vercel.app/api"
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# File Upload Configuration
MAX_FILE_SIZE="10485760"
ALLOWED_FILE_TYPES="image/jpeg,image/png,application/pdf"

# Redis (Optional - For caching and queues - Use Upstash or Redis Cloud)
REDIS_URL="redis://your-redis-url:6379"

# WebSocket Port (Not needed for Vercel serverless)
# WS_PORT="3002"

# Node Environment
NODE_ENV="production"
