// AssetFlow Database Schema
// Prisma ORM Schema
// PostgreSQL 15+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

// Authentication & RBAC Enums
enum UserRoleLevel {
  super_admin
  org_admin
  department_admin
  manager
  supervisor
  employee
  viewer
}

enum PermissionModule {
  organizations
  users
  roles
  permissions
  departments
  employees
  asset_categories
  locations
  assets
  allocations
  transfers
  bookable_resources
  bookings
  maintenance
  vendors
  audit
  reports
  notifications
  dashboard
  settings
  system
}

enum ActionType {
  create
  read
  update
  delete
  list
  export
  import
  approve
  reject
  assign
  unassign
  archive
  restore
}

// Organization Setup Enums
enum EmploymentStatus {
  active
  on_leave
  terminated
  resigned
  retired
  contractor
  intern
}

enum LocationType {
  building
  floor
  room
  desk
  warehouse
  vehicle
  remote
  other
}

// Asset Management Enums
enum AssetStatus {
  available
  allocated
  in_maintenance
  reserved
  retired
  lost
  stolen
  damaged
  disposed
  in_transit
}

enum AssetCondition {
  excellent
  good
  fair
  poor
  damaged
  non_functional
}

enum OwnershipType {
  owned
  leased
  rented
  borrowed
  loaned
}

enum DepreciationMethod {
  straight_line
  declining_balance
  units_of_production
  none
}

enum DocumentType {
  manual
  warranty
  invoice
  receipt
  certificate
  license
  insurance
  other
}

// Asset Allocation Enums
enum AllocationStatus {
  active
  returned
  overdue
  cancelled
  pending_approval
  rejected
}

enum AllocationTargetType {
  employee
  department
  project
  vendor
}

enum TransferPriority {
  low
  normal
  high
  urgent
}

enum TransferStatus {
  pending
  approved
  in_transit
  completed
  rejected
  cancelled
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

enum ConflictType {
  double_allocation
  location_mismatch
  status_conflict
  permission_conflict
}

// Resource Booking Enums
enum ResourceType {
  room
  equipment
  vehicle
  facility
  other
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  no_show
  cancelled
}

enum AttendeeStatus {
  invited
  accepted
  declined
  tentative
}

// Maintenance Enums
enum MaintenanceType {
  preventive
  corrective
  predictive
  emergency
  calibration
  upgrade
}

enum MaintenancePriority {
  low
  normal
  high
  critical
  emergency
}

enum MaintenanceStatus {
  pending
  approved
  in_progress
  on_hold
  completed
  cancelled
  rejected
}

enum MaintenanceActivityType {
  diagnosis
  repair
  replacement
  inspection
  calibration
  upgrade
  cleaning
  testing
}

enum CostType {
  labor
  parts
  materials
  travel
  other
}

// Audit Enums
enum AuditStatus {
  planned
  in_progress
  on_hold
  completed
  cancelled
}

enum AuditItemStatus {
  pending
  in_progress
  completed
  skipped
  discrepancy_found
}

enum DiscrepancyType {
  missing
  extra
  location_mismatch
  condition_mismatch
  tag_mismatch
  data_inconsistency
}

enum DiscrepancySeverity {
  low
  medium
  high
  critical
}

enum ResolutionStatus {
  open
  in_progress
  resolved
  closed
  escalated
}

// Reports Enums
enum ReportType {
  asset_inventory
  allocation_summary
  utilization
  maintenance
  audit
  financial
  custom
}

enum ScheduleType {
  daily
  weekly
  monthly
  quarterly
  yearly
  custom
}

// Notifications Enums
enum NotificationType {
  allocation
  transfer
  maintenance
  audit
  booking
  system
  approval
  reminder
  alert
}

enum NotificationPriority {
  low
  normal
  high
  urgent
}

enum NotificationChannel {
  email
  sms
  push
  in_app
  webhook
}

enum NotificationStatus {
  pending
  sent
  delivered
  read
  failed
}

// Dashboard Enums
enum WidgetType {
  chart
  metric
  table
  list
  calendar
  gauge
  map
  custom
}

// System Enums
enum SettingValueType {
  string
  number
  boolean
  json
  encrypted
}

enum LogLevel {
  debug
  info
  notice
  warning
  error
  critical
  fatal
  panic
}

// ============================================================================
// MODELS - Authentication & RBAC
// ============================================================================

model Organization {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String    @db.VarChar(255)
  slug                     String    @unique @db.VarChar(100)
  domain                   String?   @unique @db.VarChar(255)
  logoUrl                  String?   @db.VarChar(500)
  primaryColor             String?   @db.VarChar(7)
  secondaryColor           String?   @db.VarChar(7)
  timezone                 String    @default("UTC") @db.VarChar(50)
  locale                   String    @default("en-US") @db.VarChar(10)
  address                  String?   @db.Text
  phone                    String?   @db.VarChar(20)
  email                    String    @unique @db.VarChar(255)
  maxUsers                 Int       @default(100)
  maxAssets                Int       @default(1000)
  subscriptionPlan         String    @default("basic") @db.VarChar(50)
  subscriptionStatus       String    @default("active") @db.VarChar(20)
  subscriptionStart         DateTime  @default(now()) @db.Timestamp(6)
  subscriptionEnd          DateTime? @db.Timestamp(6)
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  users                    User[]
  roles                    Role[]
  departments              Department[]
  employees                Employee[]
  assetCategories          AssetCategory[]
  locations                Location[]
  assets                   Asset[]
  allocations              Allocation[]
  transfers                Transfer[]
  bookableResources        BookableResource[]
  bookings                 Booking[]
  maintenanceRequests      MaintenanceRequest[]
  vendors                  Vendor[]
  maintenanceSchedules     MaintenanceSchedule[]
  auditCycles              AuditCycle[]
  reports                  Report[]
  notificationTemplates     NotificationTemplate[]
  notificationRules        NotificationRule[]
  activityLogs             ActivityLog[]
  dashboardWidgets         DashboardWidget[]
  kpiMetrics               KpiMetric[]
  settings                 Setting[]
  featureFlags             FeatureFlag[]

  // Indexes
  @@index([slug])
  @@index([domain])
  @@index([subscriptionStatus, subscriptionEnd])
  @@map("organizations")
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  employeeId               String?   @db.Uuid
  email                    String    @db.VarChar(255)
  passwordHash             String    @db.VarChar(255)
  firstName                String    @db.VarChar(100)
  lastName                 String    @db.VarChar(100)
  displayName              String?   @db.VarChar(200)
  avatarUrl                String?   @db.VarChar(500)
  phone                    String?   @db.VarChar(20)
  departmentId             String?   @db.Uuid
  jobTitle                 String?   @db.VarChar(100)
  isActive                 Boolean   @default(true)
  isVerified               Boolean   @default(false)
  lastLoginAt              DateTime? @db.Timestamp(6)
  lastLoginIp              String?   @db.VarChar(45)
  failedLoginAttempts      Int       @default(0)
  lockedUntil              DateTime? @db.Timestamp(6)
  passwordChangedAt        DateTime  @default(now()) @db.Timestamp(6)
  mustChangePassword       Boolean   @default(false)
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecret          String?   @db.VarChar(255)
  preferences              Json?
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee                 Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  department               Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation("UserCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("UserUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  sessions                 Session[]
  passwordResetTokens      PasswordResetToken[]
  userRoles                UserRole[]
  rolePermissions          RolePermission[] @relation("RolePermissionCreatedBy")
  userRolesAssigned        UserRole[] @relation("UserRoleAssignedBy")
  assetStatusHistory       AssetStatusHistory[]
  assetPhotos              AssetPhoto[]
  assetDocuments           AssetDocument[]
  assetQrCodes             AssetQrCode[]
  assetSpecifications      AssetSpecification[]
  assetWarranties          AssetWarranty[]
  allocations              Allocation[] @relation("AllocationCreatedBy")
  allocationsUpdatedBy     Allocation[] @relation("AllocationUpdatedBy")
  allocationsApprovedBy    Allocation[] @relation("AllocationApprovedBy")
  allocationsRejectedBy    Allocation[] @relation("AllocationRejectedBy")
  transfers                Transfer[] @relation("TransferRequestedBy")
  transfersApprovedBy      Transfer[] @relation("TransferApprovedBy")
  transfersRejectedBy      Transfer[] @relation("TransferRejectedBy")
  transfersCompletedBy     Transfer[] @relation("TransferCompletedBy")
  transferApprovals        TransferApproval[]
  allocationConflicts      AllocationConflict[]
  maintenanceRequests      MaintenanceRequest[] @relation("MaintenanceRequestedBy")
  maintenanceRequestsAssignedTo MaintenanceRequest[] @relation("MaintenanceAssignedTo")
  maintenanceRequestsApprovedBy MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  maintenanceRequestsRejectedBy MaintenanceRequest[] @relation("MaintenanceRejectedBy")
  maintenanceRequestsCompletedBy MaintenanceRequest[] @relation("MaintenanceCompletedBy")
  maintenanceActivities    MaintenanceActivity[]
  maintenanceTechnicians   MaintenanceTechnician[] @relation("MaintenanceTechnicianAssignedBy")
  maintenanceSchedules     MaintenanceSchedule[]
  maintenanceApprovals     MaintenanceApproval[]
  maintenanceCosts         MaintenanceCost[]
  vendors                  Vendor[] @relation("VendorCreatedBy")
  vendorsUpdatedBy         Vendor[] @relation("VendorUpdatedBy")
  auditCycles              AuditCycle[] @relation("AuditCycleCreatedBy")
  auditCyclesUpdatedBy     AuditCycle[] @relation("AuditCycleUpdatedBy")
  auditCyclesLeadAuditor   AuditCycle[] @relation("AuditCycleLeadAuditor")
  auditAssignments         AuditAssignment[]
  auditAssignmentsAssignedBy AuditAssignment[] @relation("AuditAssignmentAssignedBy")
  auditItems               AuditItem[] @relation("AuditItemAssignedAuditor")
  auditItemsAuditedBy      AuditItem[] @relation("AuditItemAuditedBy")
  auditDiscrepancies       AuditDiscrepancy[]
  auditHistory             AuditHistory[]
  auditChecklists          AuditChecklist[] @relation("AuditChecklistCreatedBy")
  auditChecklistsUpdatedBy AuditChecklist[] @relation("AuditChecklistUpdatedBy")
  reports                  Report[] @relation("ReportCreatedBy")
  reportsUpdatedBy         Report[] @relation("ReportUpdatedBy")
  notifications            Notification[]
  notificationTemplates    NotificationTemplate[] @relation("NotificationTemplateCreatedBy")
  notificationTemplatesUpdatedBy NotificationTemplate[] @relation("NotificationTemplateUpdatedBy")
  notificationRules        NotificationRule[] @relation("NotificationRuleCreatedBy")
  notificationRulesUpdatedBy NotificationRule[] @relation("NotificationRuleUpdatedBy")
  activityLogs             ActivityLog[]
  dashboardWidgets         DashboardWidget[] @relation("DashboardWidgetCreatedBy")
  dashboardWidgetsUpdatedBy DashboardWidget[] @relation("DashboardWidgetUpdatedBy")
  bookings                 Booking[] @relation("BookingBookedBy")
  bookingsApprovedBy       Booking[] @relation("BookingApprovedBy")
  bookingsRejectedBy       Booking[] @relation("BookingRejectedBy")
  bookingsCancelledBy      Booking[] @relation("BookingCancelledBy")
  bookingHistory           BookingHistory[]
  bookingBlackouts         BookingBlackout[]
  settings                 Setting[] @relation("SettingUpdatedBy")
  featureFlags             FeatureFlag[] @relation("FeatureFlagUpdatedBy")
  systemLogs               SystemLog[]

  // Indexes
  @@unique([email])
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([isActive])
  @@index([employeeId])
  @@index([departmentId])
  @@index([lastLoginAt])
  @@map("users")
}

model Role {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  name                     String    @db.VarChar(100)
  slug                     String    @db.VarChar(100)
  description              String?   @db.Text
  isSystem                 Boolean   @default(false)
  isDefault                Boolean   @default(false)
  level                    Int       @default(0)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
  rolePermissions          RolePermission[]
  userRoles                UserRole[]

  // Indexes
  @@unique([organizationId, slug])
  @@index([level])
  @@map("roles")
}

model Permission {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String    @db.VarChar(100)
  slug                     String    @unique @db.VarChar(100)
  module                   PermissionModule
  action                   ActionType
  description              String?   @db.Text
  isSystem                 Boolean   @default(false)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  rolePermissions          RolePermission[]

  // Indexes
  @@index([module, action])
  @@map("permissions")
}

model RolePermission {
  id                       String    @id @default(uuid()) @db.Uuid
  roleId                   String    @db.Uuid
  permissionId             String    @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid

  // Relations
  role                     Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission               Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation("RolePermissionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  roleId                   String    @db.Uuid
  assignedAt               DateTime  @default(now()) @db.Timestamp(6)
  assignedBy               String?   @db.Uuid
  expiresAt                DateTime? @db.Timestamp(6)
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid

  // Relations
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                     Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser           User?       @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([expiresAt])
  @@map("user_roles")
}

model Session {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  token                    String    @unique @db.VarChar(255)
  ipAddress                String?   @db.VarChar(45)
  userAgent                String?   @db.Text
  deviceType               String?   @db.VarChar(50)
  location                 Json?
  lastActivity             DateTime  @default(now()) @db.Timestamp(6)
  expiresAt                DateTime  @db.Timestamp(6)
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  token                    String    @unique @db.VarChar(255)
  expiresAt                DateTime  @db.Timestamp(6)
  usedAt                   DateTime? @db.Timestamp(6)
  ipAddress                String?   @db.VarChar(45)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================================================
// MODELS - Organization Setup
// ============================================================================

model Department {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  parentId                 String?   @db.Uuid
  name                     String    @db.VarChar(255)
  code                     String    @db.VarChar(50)
  description              String?   @db.Text
  managerId                String?   @db.Uuid
  locationId               String?   @db.Uuid
  budget                   Decimal?  @db.Decimal(15, 2)
  employeeCount            Int       @default(0)
  isActive                 Boolean   @default(true)
  level                    Int       @default(0)
  path                     String?   @db.VarChar(1000)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent                   Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                 Department[] @relation("DepartmentHierarchy")
  manager                  Employee?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  managedDepartments       Department[] @relation("DepartmentManagedBy")
  location                 Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  employees                Employee[]
  assets                   Asset[] @relation("AssetAssignedDepartment")
  allocations              Allocation[] @relation("AllocationDepartment")
  transfersFrom            Transfer[] @relation("TransferFromDepartment")
  transfersTo              Transfer[] @relation("TransferToDepartment")
  auditAssignments         AuditAssignment[]

  // Indexes
  @@unique([organizationId, code])
  @@index([parentId])
  @@index([isActive])
  @@index([managerId])
  @@map("departments")
}

model Employee {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  departmentId             String?   @db.Uuid
  employeeNumber           String    @db.VarChar(50)
  firstName                String    @db.VarChar(100)
  lastName                 String    @db.VarChar(100)
  displayName              String?   @db.VarChar(200)
  email                    String    @db.VarChar(255)
  phone                    String?   @db.VarChar(20)
  jobTitle                 String?   @db.VarChar(100)
  managerId                String?   @db.Uuid
  locationId               String?   @db.Uuid
  hireDate                 DateTime  @db.Date
  terminationDate           DateTime? @db.Date
  employmentStatus         EmploymentStatus @default(active)
  avatarUrl                String?   @db.VarChar(500)
  address                  Json?
  emergencyContact          Json?
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department               Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager                  Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports            Employee[] @relation("EmployeeManager")
  location                 Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  users                    User[]
  managedDepartments       Department[] @relation("DepartmentManagedBy")
  assets                   Asset[] @relation("AssetAssignedTo")
  allocations              Allocation[] @relation("AllocationEmployee")
  transfersFrom            Transfer[] @relation("TransferFromEmployee")
  transfersTo              Transfer[] @relation("TransferToEmployee")
  locations                Location[] @relation("LocationManager")
  bookingAttendees         BookingAttendee[]
  maintenanceTechnicians   MaintenanceTechnician[]
  auditAssignments         AuditAssignment[]

  // Indexes
  @@unique([organizationId, employeeNumber])
  @@unique([organizationId, email])
  @@index([departmentId])
  @@index([managerId])
  @@index([locationId])
  @@index([employmentStatus])
  @@map("employees")
}

model AssetCategory {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  parentId                 String?   @db.Uuid
  name                     String    @db.VarChar(255)
  code                     String    @db.VarChar(50)
  description              String?   @db.Text
  icon                     String?   @db.VarChar(100)
  color                    String?   @db.VarChar(7)
  depreciationMethod       DepreciationMethod?
  depreciationRate          Decimal?  @db.Decimal(5, 2)
  usefulLifeYears          Int?
  requiresMaintenance      Boolean   @default(true)
  maintenanceIntervalDays  Int?
  isActive                 Boolean   @default(true)
  level                    Int       @default(0)
  path                     String?   @db.VarChar(1000)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent                   AssetCategory? @relation("AssetCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                 AssetCategory[] @relation("AssetCategoryHierarchy")
  assets                   Asset[]
  auditChecklists          AuditChecklist[]

  // Indexes
  @@unique([organizationId, code])
  @@index([parentId])
  @@index([isActive])
  @@map("asset_categories")
}

model Location {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  parentId                 String?   @db.Uuid
  name                     String    @db.VarChar(255)
  code                     String    @db.VarChar(50)
  type                     LocationType @default(building)
  address                  Json?
  coordinates              Json?
  floor                    String?   @db.VarChar(50)
  room                     String?   @db.VarChar(50)
  capacity                 Int?
  managerId                String?   @db.Uuid
  isActive                 Boolean   @default(true)
  level                    Int       @default(0)
  path                     String?   @db.VarChar(1000)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent                   Location?   @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                 Location[] @relation("LocationHierarchy")
  manager                  Employee?   @relation("LocationManager", fields: [managerId], references: [id], onDelete: SetNull)
  managedLocations         Location[] @relation("LocationManager")
  departments              Department[]
  employees                Employee[]
  assets                   Asset[]
  bookableResources        BookableResource[]
  auditAssignments         AuditAssignment[] @relation("AuditAssignmentLocation")
  auditItems               AuditItem[] @relation("AuditItemAssignedLocation")
  auditItemsExpected        AuditItem[] @relation("AuditItemExpectedLocation")
  auditItemsActual         AuditItem[] @relation("AuditItemActualLocation")

  // Indexes
  @@unique([organizationId, code])
  @@index([parentId])
  @@index([type])
  @@index([managerId])
  @@map("locations")
}

model LocationHierarchy {
  id                       String    @id @default(uuid()) @db.Uuid
  ancestorId               String    @db.Uuid
  descendantId             String    @db.Uuid
  depth                    Int       @default(0)

  // Relations
  ancestor                 Location   @relation("LocationHierarchyAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendants              Location[] @relation("LocationHierarchyAncestor")
  descendant               Location   @relation("LocationHierarchyDescendant", fields: [descendantId], references: [id], onDelete: Cascade)
