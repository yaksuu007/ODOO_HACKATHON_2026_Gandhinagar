  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category                 AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  location                 Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignedToEmployee       Employee?   @relation("AssetAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  assignedDepartment        Department? @relation("AssetAssignedDepartment", fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation("AssetCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("AssetUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  statusHistory            AssetStatusHistory[]
  photos                   AssetPhoto[]
  documents                AssetDocument[]
  qrCodes                  AssetQrCode[]
  specifications           AssetSpecification[]
  warranties               AssetWarranty[]
  depreciation             AssetDepreciation
  allocations              Allocation[]
  transfers                Transfer[]
  maintenanceRequests      MaintenanceRequest[]
  maintenanceSchedules     MaintenanceSchedule[]
  auditItems               AuditItem[]

  // Indexes
  @@unique([organizationId, assetTag])
  @@unique([organizationId, serialNumber])
  @@unique([organizationId, qrCode])
  @@unique([organizationId, barcode])
  @@index([categoryId])
  @@index([locationId])
  @@index([status])
  @@index([assignedTo])
  @@index([assignedDepartmentId])
  @@index([isBookable])
  @@index([purchaseDate])
  @@index([warrantyExpiry])
