model MaintenanceRequest {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  assetId                  String    @db.Uuid
  requestNumber            String    @db.VarChar(50)
  requestedBy              String    @db.Uuid
  assignedTo               String?   @db.Uuid
  vendorId                 String?   @db.Uuid
  type                     MaintenanceType
  priority                 MaintenancePriority @default(normal)
  status                   MaintenanceStatus @default(pending)
  requestedDate            DateTime  @default(now()) @db.Timestamp(6)
  targetCompletionDate     DateTime? @db.Date
  actualCompletionDate     DateTime? @db.Timestamp(6)
  description              String    @db.Text
  estimatedCost            Decimal?  @db.Decimal(15, 2)
  actualCost               Decimal?  @db.Decimal(15, 2)
  approvedBy               String?   @db.Uuid
  approvedAt               DateTime? @db.Timestamp(6)
  rejectedBy               String?   @db.Uuid
  rejectedAt               DateTime? @db.Timestamp(6)
  rejectionReason          String?   @db.Text
  completedBy              String?   @db.Uuid
  notes                    String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset                    Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedByUser          User        @relation("MaintenanceRequestedBy", fields: [requestedBy], references: [id])
  assignedToUser           User?       @relation("MaintenanceAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  vendor                   Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  approvedByUser           User?       @relation("MaintenanceApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejectedByUser           User?       @relation("MaintenanceRejectedBy", fields: [rejectedBy], references: [id], onDelete: SetNull)
  completedByUser          User?       @relation("MaintenanceCompletedBy", fields: [completedBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  activities               MaintenanceActivity[]
  technicians              MaintenanceTechnician[]
  approvals                MaintenanceApproval[]
  costs                    MaintenanceCost[]
  assetStatusHistory       AssetStatusHistory[]

  // Indexes
  @@unique([organizationId, requestNumber])
  @@index([assetId])
  @@index([assignedTo])
  @@index([vendorId])
  @@index([status])
  @@index([priority, status])
  @@index([type])
  @@index([targetCompletionDate])
  @@map("maintenance_requests")
}

model MaintenanceActivity {
  id                       String    @id @default(uuid()) @db.Uuid
  maintenanceRequestId     String    @db.Uuid
  activityType             MaintenanceActivityType
  description              String?   @db.Text
  durationMinutes          Int?
  cost                     Decimal?  @db.Decimal(15, 2)
  performedAt              DateTime  @default(now()) @db.Timestamp(6)
  performedBy              String?   @db.Uuid

  // Relations
  maintenanceRequest       MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  performedByUser          User?       @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([maintenanceRequestId, performedAt(sort: Desc)])
  @@index([activityType])
  @@map("maintenance_activities")
}

model MaintenanceTechnician {
  id                       String    @id @default(uuid()) @db.Uuid
  maintenanceRequestId     String    @db.Uuid
  userId                   String    @db.Uuid
  assignedBy               String?   @db.Uuid
  isPrimary                Boolean   @default(false)
  assignedAt               DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  maintenanceRequest       MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser           User?       @relation("MaintenanceTechnicianAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([maintenanceRequestId])
  @@index([userId])
  @@index([isPrimary])
  @@map("maintenance_technicians")
}

model Vendor {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  code                     String    @db.VarChar(50)
  name                     String    @db.VarChar(255)
  contactPerson            String?   @db.VarChar(255)
  email                    String?   @db.VarChar(255)
  phone                    String?   @db.VarChar(20)
  address                  String?   @db.Text
  rating                   Decimal?  @db.Decimal(3, 2)
  contractStart            DateTime? @db.Date
  contractEnd              DateTime? @db.Date
  notes                    String?   @db.Text
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation("VendorCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("VendorUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  maintenanceRequests      MaintenanceRequest[]
  maintenanceCosts         MaintenanceCost[]

  // Indexes
  @@unique([organizationId, code])
  @@index([isActive])
  @@index([rating])
  @@map("vendors")
}

model MaintenanceSchedule {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  assetId                  String    @db.Uuid
  name                     String    @db.VarChar(255)
  type                     MaintenanceType
  scheduleType             ScheduleType
  intervalValue            Int?
  startDate               DateTime  @db.Date
  endDate                  DateTime? @db.Date
