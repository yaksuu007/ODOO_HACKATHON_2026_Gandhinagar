model MaintenanceApproval {
  id                       String    @id @default(uuid()) @db.Uuid
  maintenanceRequestId     String    @db.Uuid
  approverId               String    @db.Uuid
  approvalLevel            Int       @default(1)
  status                   ApprovalStatus @default(pending)
  approvedAt               DateTime? @db.Timestamp(6)
  rejectedAt               DateTime? @db.Timestamp(6)
  comments                 String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  maintenanceRequest       MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  approver                 User        @relation(fields: [approverId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([maintenanceRequestId, approverId])
  @@index([maintenanceRequestId])
  @@index([approverId])
  @@index([status])
  @@map("maintenance_approvals")
}

model MaintenanceCost {
  id                       String    @id @default(uuid()) @db.Uuid
  maintenanceRequestId     String    @db.Uuid
  vendorId                 String?   @db.Uuid
  costType                 CostType
  description              String?   @db.Text
  amount                   Decimal    @db.Decimal(15, 2)
  incurredAt               DateTime  @db.Date
  invoiceNumber            String?   @db.VarChar(100)
  createdBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  maintenanceRequest       MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  vendor                   Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([maintenanceRequestId])
  @@index([costType])
  @@index([vendorId])
  @@index([incurredAt])
  @@map("maintenance_costs")
}

// ============================================================================
// MODELS - Audit
// ============================================================================

model AuditCycle {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  code                     String    @db.VarChar(50)
  name                     String    @db.VarChar(255)
  description              String?   @db.Text
  checklistId              String?   @db.Uuid
  leadAuditorId            String?   @db.Uuid
  plannedStartDate         DateTime  @db.Date
  plannedEndDate           DateTime  @db.Date
  startDate               DateTime? @db.Date
  endDate                  DateTime? @db.Date
  status                   AuditStatus @default(planned)
  totalAssets              Int       @default(0)
  auditedAssets            Int       @default(0)
  discrepancyCount         Int       @default(0)
  notes                    String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  checklist                AuditChecklist? @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  leadAuditor              User?       @relation("AuditCycleLeadAuditor", fields: [leadAuditorId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation("AuditCycleCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("AuditCycleUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  assignments              AuditAssignment[]
  items                    AuditItem[]
  history                  AuditHistory[]

  // Indexes
  @@unique([organizationId, code])
  @@index([status])
  @@index([startDate, endDate])
  @@index([leadAuditorId])
  @@index([checklistId])
  @@map("audit_cycles")
}

model AuditAssignment {
  id                       String    @id @default(uuid()) @db.Uuid
  auditCycleId             String    @db.Uuid
  userId                   String    @db.Uuid
  assignedLocationId       String?   @db.Uuid
  assignedDepartmentId     String?   @db.Uuid
  role                     String    @db.VarChar(50)
  assetCount               Int       @default(0)
  completedCount           Int       @default(0)
  assignedAt               DateTime  @default(now()) @db.Timestamp(6)
  assignedBy               String?   @db.Uuid

  // Relations
  auditCycle               AuditCycle  @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedLocation         Location?   @relation("AuditAssignmentLocation", fields: [assignedLocationId], references: [id], onDelete: SetNull)
  assignedDepartment       Department? @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  assignedByUser           User?       @relation("AuditAssignmentAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([auditCycleId, userId])
  @@index([assignedLocationId])
  @@index([assignedDepartmentId])
  @@index([role])
  @@map("audit_assignments")
}

model AuditItem {
  id                       String    @id @default(uuid()) @db.Uuid
  auditCycleId             String    @db.Uuid
  assetId                  String    @db.Uuid
  assignedAuditorId        String?   @db.Uuid
  assignedLocationId       String?   @db.Uuid
  expectedLocationId       String?   @db.Uuid
  actualLocationId         String?   @db.Uuid
  status                   AuditItemStatus @default(pending)
  auditedAt                DateTime? @db.Timestamp(6)
  auditedBy                String?   @db.Uuid
  notes                    String?   @db.Text
  hasDiscrepancy           Boolean   @default(false)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  auditCycle               AuditCycle  @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset                    Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignedAuditor          User?       @relation("AuditItemAssignedAuditor", fields: [assignedAuditorId], references: [id], onDelete: SetNull)
  auditedByUser            User?       @relation("AuditItemAuditedBy", fields: [auditedBy], references: [id], onDelete: SetNull)
  assignedLocation         Location?   @relation("AuditItemAssignedLocation", fields: [assignedLocationId], references: [id], onDelete: SetNull)
  expectedLocation         Location?   @relation("AuditItemExpectedLocation", fields: [expectedLocationId], references: [id], onDelete: SetNull)
  actualLocation           Location?   @relation("AuditItemActualLocation", fields: [actualLocationId], references: [id], onDelete: SetNull)
  discrepancies            AuditDiscrepancy[]

  // Indexes
  @@unique([auditCycleId, assetId])
  @@index([assignedAuditorId])
  @@index([status])
  @@index([hasDiscrepancy])
  @@map("audit_items")
}

model AuditDiscrepancy {
  id                       String    @id @default(uuid()) @db.Uuid
  auditItemId              String    @db.Uuid
  discrepancyType         DiscrepancyType
  description              String    @db.Text
  severity                 DiscrepancySeverity @default(medium)
  resolutionStatus         ResolutionStatus @default(open)
  resolvedAt               DateTime? @db.Timestamp(6)
  resolvedBy               String?   @db.Uuid
  resolutionNotes          String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  auditItem                AuditItem   @relation(fields: [auditItemId], references: [id], onDelete: Cascade)
  resolvedByUser           User?       @relation(fields: [resolvedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([discrepancyType])
  @@index([severity])
  @@index([resolutionStatus])
  @@map("audit_discrepancies")
}

model AuditHistory {
  id                       String    @id @default(uuid()) @db.Uuid
  auditCycleId             String    @db.Uuid
  action                   ActionType
  fromStatus               AuditStatus?
  toStatus                 AuditStatus
  changes                  Json?
  performedAt              DateTime  @default(now()) @db.Timestamp(6)
  performedBy              String?   @db.Uuid
  notes                    String?   @db.Text

  // Relations
  auditCycle               AuditCycle  @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  performedByUser          User?       @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([auditCycleId, performedAt(sort: Desc)])
  @@map("audit_history")
}

model AuditChecklist {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  categoryId               String?   @db.Uuid
  code                     String    @db.VarChar(50)
  name                     String    @db.VarChar(255)
  description              String?   @db.Text
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category                 AssetCategory @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation("AuditChecklistCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("AuditChecklistUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  items                    AuditChecklistItem[]
  auditCycles              AuditCycle[]

  // Indexes
  @@unique([organizationId, code])
  @@index([isActive])
  @@index([categoryId])
  @@map("audit_checklists")
}

model AuditChecklistItem {
  id                       String    @id @default(uuid()) @db.Uuid
  checklistId              String    @db.Uuid
  itemText                 String    @db.Text
  itemType                 String    @default("checkbox") @db.VarChar(50)
  orderIndex               Int       @default(0)
  isRequired               Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  checklist                AuditChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([checklistId, orderIndex])
  @@map("audit_checklist_items")
}

// ============================================================================
// MODELS - Reports
// ============================================================================

model Report {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  name                     String    @db.VarChar(255)
  slug                     String    @db.VarChar(100)
  description              String?   @db.Text
  reportType               ReportType
  queryConfig              Json
  isPublic                 Boolean   @default(false)
  isSystem                 Boolean   @default(false)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation("ReportCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("ReportUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  schedules                ReportSchedule[]
  subscriptions            ReportSubscription[]

  // Indexes
  @@unique([organizationId, slug])
  @@index([reportType])
  @@index([isPublic])
  @@index([isSystem])
  @@map("reports")
}

model ReportSchedule {
  id                       String    @id @default(uuid()) @db.Uuid
  reportId                 String    @db.Uuid
  scheduleType             ScheduleType
  intervalValue            Int?
  dayOfWeek                Int?
  dayOfMonth               Int?
  time                     DateTime  @default("00:00") @db.Time
  nextRunAt                DateTime  @db.Timestamp(6)
  lastRunAt                DateTime? @db.Timestamp(6)
  isActive                 Boolean   @default(true)
  recipients               Json?
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  report                   Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  updatedByUser            User?       @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([reportId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("report_schedules")
}

model ReportSubscription {
  id                       String    @id @default(uuid()) @db.Uuid
  reportId                 String    @db.Uuid
  userId                   String    @db.Uuid
  deliveryMethod           NotificationChannel @default(email)
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  report                   Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([reportId, userId])
  @@index([isActive])
  @@map("report_subscriptions")
}

// ============================================================================
// MODELS - Notifications
// ============================================================================

model Notification {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  userId                   String    @db.Uuid
  type                     NotificationType
  title                    String    @db.VarChar(255)
  message                  String    @db.Text
  priority                 NotificationPriority @default(normal)
  isRead                   Boolean   @default(false)
  readAt                   DateTime? @db.Timestamp(6)
  expiresAt                DateTime? @db.Timestamp(6)
  relatedEntityType         String?   @db.VarChar(50)
  relatedEntityId          String?   @db.Uuid
  actionUrl                String?   @db.VarChar(500)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs                     NotificationLog[]

  // Indexes
  @@index([userId])
  @@index([type])
  @@index([priority])
  @@index([isRead])
  @@index([expiresAt])
  @@index([relatedEntityType, relatedEntityId])
  @@map("notifications")
}

model NotificationTemplate {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  type                     NotificationType
  name                     String    @db.VarChar(255)
  slug                     String    @db.VarChar(100)
  subjectTemplate          String    @db.Text
  bodyTemplate             String    @db.Text
  isActive                 Boolean   @default(true)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation("NotificationTemplateCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("NotificationTemplateUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  rules                    NotificationRule[]

  // Indexes
  @@unique([organizationId, slug])
  @@index([type])
  @@index([isActive])
  @@map("notification_templates")
}

model NotificationPreference {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  notificationType         NotificationType
  channels                 Json      @default("{\"email\": true, \"in_app\": true}")
  isEnabled                Boolean   @default(true)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([userId, notificationType])
  @@map("notification_preferences")
}

model NotificationRule {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  templateId               String?   @db.Uuid
  triggerEvent             String    @db.VarChar(100)
  conditions               Json?
  isActive                 Boolean   @default(true)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template                 NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdByUser            User?       @relation("NotificationRuleCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("NotificationRuleUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@index([isActive])
  @@index([triggerEvent])
  @@map("notification_rules")
}

model NotificationLog {
  id                       String    @id @default(uuid()) @db.Uuid
  notificationId           String    @db.Uuid
  channel                  NotificationChannel
  recipient                String    @db.VarChar(255)
  status                   NotificationStatus @default(pending)
  errorMessage             String?   @db.Text
  sentAt                   DateTime? @db.Timestamp(6)
  retryCount               Int       @default(0)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  notification             Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([notificationId])
  @@index([channel])
  @@index([status])
  @@index([retryCount])
  @@map("notification_logs")
}

// ============================================================================
// MODELS - Activity Logs
// ============================================================================

model ActivityLog {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  userId                   String?   @db.Uuid
  action                   ActionType
  entityType               String    @db.VarChar(100)
  entityId                 String?   @db.Uuid
  changes                  Json?
  ipAddress                String?   @db.VarChar(45)
  userAgent                String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  details                  ActivityLogDetail[]

  // Indexes
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model ActivityLogDetail {
  id                       String    @id @default(uuid()) @db.Uuid
  activityLogId            String    @db.Uuid
  detailKey                String    @db.VarChar(255)
  detailValue              String?   @db.Text
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  activityLog              ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([activityLogId])
  @@map("activity_log_details")
}

// ============================================================================
// MODELS - Dashboard
// ============================================================================

model DashboardConfig {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  config                   Json      @default("{}")
  isDefault                Boolean   @default(false)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([userId])
  @@index([isDefault])
  @@map("dashboard_configs")
}

model DashboardWidget {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  name                     String    @db.VarChar(255)
  slug                     String    @db.VarChar(100)
  widgetType               WidgetType
  description              String?   @db.Text
  config                   Json      @default("{}")
  isActive                 Boolean   @default(true)
  isSystem                 Boolean   @default(false)
  createdBy                String?   @db.Uuid
  updatedBy                String?   @db.Uuid
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)
  deletedAt                DateTime? @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser            User?       @relation("DashboardWidgetCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser            User?       @relation("DashboardWidgetUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([organizationId, slug])
  @@index([widgetType])
  @@index([isActive])
  @@map("dashboard_widgets")
}

model KpiMetric {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String    @db.Uuid
  metricName               String    @db.VarChar(255)
  metricValue              Decimal    @db.Decimal(20, 2)
  periodStart              DateTime  @db.Date
  periodEnd                DateTime  @db.Date
  dimensions               Json?
  createdAt                DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Indexes
  @@unique([organizationId, metricName, periodStart, periodEnd])
  @@index([metricName])
  @@index([periodStart, periodEnd])
  @@map("kpi_metrics")
}

// ============================================================================
// MODELS - System
// ============================================================================

model Setting {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String?   @db.Uuid
  key                      String    @db.VarChar(255)
  value                    String    @db.Text
  valueType                SettingValueType @default(string)
  description              String?   @db.Text
  isPublic                 Boolean   @default(false)
  updatedBy                String?   @db.Uuid
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  organization             Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedByUser            User?       @relation("SettingUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([organizationId, key])
  // Note: Partial unique constraint uq_settings_global_key (WHERE organizationId IS NULL) exists in SQL
  @@map("settings")
}

model FeatureFlag {
  id                       String    @id @default(uuid()) @db.Uuid
  organizationId           String?   @db.Uuid
  featureName              String    @db.VarChar(255)
  isEnabled                Boolean   @default(false)
  description              String?   @db.Text
  rolloutPercentage        Int       @default(0)
  updatedBy                String?   @db.Uuid
  updatedAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  organization             Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedByUser            User?       @relation("FeatureFlagUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Indexes
  @@unique([organizationId, featureName])
  // Note: Partial unique constraint uq_feature_flags_global_name (WHERE organizationId IS NULL) exists in SQL
  @@index([isEnabled])
  @@map("feature_flags")
}

model SystemLog {
  id                       String    @id @default(uuid()) @db.Uuid
  level                    LogLevel
  service                  String?   @db.VarChar(100)
  message                  String    @db.Text
  context                  Json?
  traceId                  String?   @db.VarChar(255)
  userId                   String?   @db.Uuid
  ipAddress                String?   @db.VarChar(45)
  createdAt                DateTime  @default(now()) @db.Timestamp(6)

  // Relations
  user                     User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([level])
  @@index([service])
  @@index([traceId])
  @@index([createdAt(sort: Desc)])
  @@index([level, createdAt])
  @@map("system_logs")
}

// ============================================================================
// SQL CONSTRAINTS NOT REPRESENTABLE IN PRISMA
// ============================================================================

// The following constraints exist in the SQL migration and must remain there:
//
// CHECK CONSTRAINTS:
// - All CHECK constraints from the SQL files (e.g., positive values, date comparisons)
// - These are enforced at the database level and cannot be represented in Prisma
//
// EXCLUSION CONSTRAINTS:
// - ex_booking_overlap: Prevent overlapping bookings for the same resource
// - ex_allocation_double_active: Prevent double active allocation for the same asset
// - These use GIST indexes and cannot be represented in Prisma
//
// PARTIAL INDEXES:
// - Many partial indexes with WHERE clauses exist in the SQL
// - Prisma does not support partial indexes, these must remain in SQL
//
// COMPOSITE CHECK CONSTRAINTS:
// - chk_allocation_target_specified
// - chk_transfer_target_specified
// - chk_booking_attendee_identifier
// - These complex CHECK constraints cannot be represented in Prisma
//
// UNIQUE CONSTRAINTS WITH NULLS NOT DISTINCT:
// - uq_settings_global_key
// - uq_feature_flags_global_name
// - These use WHERE clauses and cannot be represented in Prisma

